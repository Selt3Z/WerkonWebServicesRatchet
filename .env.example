# Copy this file to .env and fill in real values.
# .env is ignored by git and must never be committed.

# PostgreSQL container
POSTGRES_DB=ratchet_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# API: connection string (host "postgres" inside docker compose, "localhost" for local IDE runs)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=ratchet_db;Username=postgres;Password=change-me

# API: seed admin (used only when the admin user does not exist yet)
Seed__AdminUserName=admin
Seed__AdminPassword=change-me-Strong1!
Seed__AdminDisplayName=Administrator

# Application timezone
AppTimeZone=Europe/Moscow

# Site hostname. First time: run docker\setup-hosts.ps1 as Administrator
APP_HOSTNAME=ratchet.local

# Reverse proxy (Caddy)
HTTP_PORT=80
HTTPS_PORT=443
CADDY_ADDRESS=ratchet.local
CADDY_GLOBAL_OPTIONS=auto_https off
# Production (LAN only): keep auto_https off, point internal DNS or hosts on each PC
# to the server IP, e.g. 192.168.1.50 ratchet.local
# CADDY_GLOBAL_OPTIONS=

# Optional: host LAN IP shown on System Status (comma-separated)
# LAN_ADDRESSES=192.168.1.50

# Scheduled PostgreSQL backups (./backups on the project disk)
BACKUP_INTERVAL_SECONDS=86400
DAILY_RETENTION_DAYS=7
WEEKLY_RETENTION_WEEKS=4

# Encrypted restic copy on a separate local disk (recommended: second physical drive)
# 1. Create a folder on the second disk, e.g. D:\RatchetBackups\restic-repo
# 2. Use forward slashes in .env on Windows: D:/RatchetBackups/restic-repo
# 3. Set RESTIC_REPOSITORY=/restic-repo (path inside the backup container)
RESTIC_HOST_PATH=
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
RESTIC_HOST_TAG=ratchet-server
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
