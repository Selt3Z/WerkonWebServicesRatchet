@page "/vehicles/{VehicleId:guid}/visits/new"
@page "/visits/{Id:guid}/edit"
@using Microsoft.AspNetCore.Components
@using WerkonWebServicesRatchet.Web.Models
@using WerkonWebServicesRatchet.Web.Services
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager
@inject AppTimeZone AppTimeZone

<PageTitle>@(IsEditMode ? L["Visit_EditTitle"] : L["Visit_New"])</PageTitle>

<h1>@(IsEditMode ? L["Visit_EditTitle"] : L["Visit_New"])</h1>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <EditForm Model="Model" FormName="visit-save-form" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">@L["VisitDateTime"]</label>
            <input class="form-control"
                   type="datetime-local"
                   value="@VisitedAtLocalString"
                   @oninput="OnVisitedAtInput" />
            <ValidationMessage For="() => Model.VisitedAtLocal" />
        </div>

        <div class="mb-3">
            <label class="form-label">@L["Mileage"]</label>
            <InputNumber class="form-control" @bind-Value="Model.MileageAtVisit" />
            <ValidationMessage For="() => Model.MileageAtVisit" />
        </div>

        <div class="mb-3">
            <label class="form-label">@L["CustomerComplaint"]</label>
            <InputTextArea class="form-control" @bind-Value="Model.CustomerComplaint" />
            <ValidationMessage For="() => Model.CustomerComplaint" />
        </div>

        <div class="mb-3">
            <label class="form-label">@L["MechanicComment"]</label>
            <InputTextArea class="form-control" @bind-Value="Model.MechanicComment" />
        </div>

        <button type="submit" class="btn btn-primary me-2" disabled="@IsSaving">
            @(IsSaving ? L["Saving"] : L["Save"])
        </button>

        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            @L["Cancel"]
        </button>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? VehicleId { get; set; }

    [Parameter]
    public Guid? Id { get; set; }

    private VisitSaveModel Model { get; set; } = new();
    private string VisitedAtLocalString { get; set; } = string.Empty;
    private bool IsCreateInitialized { get; set; }
    private bool IsLoading { get; set; }
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }

    private bool IsEditMode => Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;

        if (!IsEditMode)
        {
            if (!IsCreateInitialized)
            {
                Model = new VisitSaveModel
                {
                    VisitedAtLocal = AppTimeZone.FromUtc(DateTime.UtcNow)
                };
                VisitedAtLocalString = ToDateTimeLocalString(Model.VisitedAtLocal);
                IsCreateInitialized = true;
            }
            return;
        }

        try
        {
            IsLoading = true;

            var visit = await ApiClient.GetVisitAsync(Id!.Value);

            if (visit is null)
            {
                ErrorMessage = L["Visit_NotFound"];
                return;
            }

            if (visit.Status is VisitStatuses.Completed or VisitStatuses.Canceled)
            {
                NavigationManager.NavigateTo($"/visits/{Id!.Value}");
                return;
            }

            VehicleId = visit.VehicleId;

            Model = new VisitSaveModel
            {
                VisitedAtLocal = AppTimeZone.FromUtc(visit.VisitedAtUtc),
                MileageAtVisit = visit.MileageAtVisit,
                CustomerComplaint = visit.CustomerComplaint,
                MechanicComment = visit.MechanicComment
            };
            VisitedAtLocalString = ToDateTimeLocalString(Model.VisitedAtLocal);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            IsSaving = true;
            ErrorMessage = null;

            if (!TryParseDateTimeLocal(VisitedAtLocalString, out var visitedAtLocal))
            {
                ErrorMessage = L["Validation_VisitDateRequired"];
                return;
            }

            Model.VisitedAtLocal = visitedAtLocal;

            VisitListItem? savedVisit;

            if (IsEditMode)
            {
                savedVisit = await ApiClient.UpdateVisitAsync(Id!.Value, Model);
            }
            else
            {
                if (!VehicleId.HasValue)
                {
                    ErrorMessage = L["VehicleIdRequired"];
                    return;
                }

                savedVisit = await ApiClient.CreateVisitAsync(VehicleId.Value, Model);
            }

            if (savedVisit is null)
            {
                ErrorMessage = L["FailedSaveVisit"];
                return;
            }

            NavigationManager.NavigateTo($"/visits/{savedVisit.Id}");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void OnVisitedAtInput(ChangeEventArgs e)
    {
        VisitedAtLocalString = e.Value?.ToString() ?? string.Empty;
    }

    private static bool TryParseDateTimeLocal(string value, out DateTime result)
    {
        if (DateTime.TryParse(value, out result))
        {
            return true;
        }

        return DateTime.TryParseExact(
            value,
            "yyyy-MM-ddTHH:mm",
            provider: null,
            System.Globalization.DateTimeStyles.None,
            out result);
    }

    private static string ToDateTimeLocalString(DateTime? value) =>
        value.HasValue ? value.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty;

    private void Cancel()
    {
        if (IsEditMode && Id.HasValue)
        {
            NavigationManager.NavigateTo($"/visits/{Id.Value}");
            return;
        }

        if (VehicleId.HasValue)
        {
            NavigationManager.NavigateTo($"/vehicles/{VehicleId.Value}");
            return;
        }

        NavigationManager.NavigateTo("/clients");
    }
}
