@page "/vehicles/{Id:guid}"
@using Microsoft.AspNetCore.Components
@using WerkonWebServicesRatchet.Web.Models
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>@L["VehicleDetails_Title"]</PageTitle>

<h1>@L["VehicleDetails_Title"]</h1>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Vehicle is null)
{
    <p>@L["Vehicle_NotFound"]</p>
}
else
{
    <div class="mb-4">
        <h3>@Vehicle.Brand @Vehicle.Model</h3>
        <p><strong>@L["Year"]:</strong> @Vehicle.Year</p>
        <p><strong>@L["LicensePlate"]:</strong> @Vehicle.LicensePlate</p>
        <p><strong>@L["Vin"]:</strong> @Vehicle.Vin</p>

        <button class="btn btn-primary" @onclick="EditVehicle">@L["Vehicle_Edit"]</button>
        <button class="btn btn-success" @onclick="AddVisit">@L["Vehicle_AddVisit"]</button>
    </div>

    <div class="mb-4">
        <h4>@L["Client"]</h4>
        <p><strong>@L["Name"]:</strong> @Vehicle.ClientFullName</p>
        <p><strong>@L["Phone"]:</strong> @Vehicle.ClientPhoneNumber</p>
        <button class="btn btn-sm btn-outline-secondary"
                @onclick="() => OpenClient(Vehicle.ClientId)">
            @L["OpenClient"]
        </button>
    </div>

    <h4>@L["Visits"]</h4>

    @if (Vehicle.Visits.Count == 0)
    {
        <p>@L["Visits_None"]</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>@L["Date"]</th>
                    <th>@L["Mileage"]</th>
                    <th>@L["Complaint"]</th>
                    <th>@L["Status"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var visit in Vehicle.Visits)
                {
                    <tr>
                        <td>@visit.VisitedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@visit.MileageAtVisit</td>
                        <td>@visit.CustomerComplaint</td>
                        <td>@L.GetVisitStatus(visit.Status)</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => OpenVisit(visit.Id)">
                                @L["Open"]
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <button class="btn btn-secondary" @onclick="BackToClient">
        @L["BackToClient"]
    </button>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private VehicleDetailsModel? Vehicle { get; set; }
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadVehicleAsync();
    }

    private async Task LoadVehicleAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            Vehicle = await ApiClient.GetVehicleDetailsAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OpenClient(Guid clientId)
    {
        NavigationManager.NavigateTo($"/clients/{clientId}");
    }

    private void OpenVisit(Guid visitId)
    {
        NavigationManager.NavigateTo($"/visits/{visitId}");
    }

    private void BackToClient()
    {
        if (Vehicle is not null)
        {
            NavigationManager.NavigateTo($"/clients/{Vehicle.ClientId}");
        }
        else
        {
            NavigationManager.NavigateTo("/clients");
        }
    }

    private void EditVehicle()
    {
        NavigationManager.NavigateTo($"/vehicles/{Id}/edit");
    }

    private void AddVisit()
    {
        NavigationManager.NavigateTo($"/vehicles/{Id}/visits/new");
    }
}
