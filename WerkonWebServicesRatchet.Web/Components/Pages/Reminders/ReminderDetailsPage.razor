@page "/reminders/{Id:guid}"
@using Microsoft.AspNetCore.Components
@using WerkonWebServicesRatchet.Web.Models
@using WerkonWebServicesRatchet.Web.Services
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AppTimeZone AppTimeZone

<PageTitle>@L["Reminder_DetailsTitle"]</PageTitle>

<h1 class="d-flex align-items-center gap-2">
    @L["Reminder_DetailsTitle"]
    @if (Reminder?.IsClosed == true)
    {
        <span class="reminder-check" title="@L["Reminder_Closed"]" aria-label="@L["Reminder_Closed"]">✔</span>
    }
</h1>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Reminder is null)
{
    <p>@L["Reminder_NotFound"]</p>
}
else
{
    <div class="detail-page">
        <div class="entity-panel">
            <div class="entity-header">
                <h2 class="entity-title">
                    @AppTimeZone.FromUtc(Reminder.ReminderAtUtc).ToString("yyyy-MM-dd")
                    @if (Reminder.IsClosed)
                    {
                        <span class="reminder-check ms-1" title="@L["Reminder_Closed"]">✔</span>
                    }
                </h2>
            </div>

            <dl class="entity-meta">
                @if (!string.IsNullOrWhiteSpace(Reminder.Note))
                {
                    <div class="entity-meta-item entity-meta-wide">
                        <dt>@L["Reminder_Note"]</dt>
                        <dd>@Reminder.Note</dd>
                    </div>
                }
                <div class="entity-meta-item">
                    <dt>@L["Client"]</dt>
                    <dd>@Reminder.ClientFullName</dd>
                </div>
                <div class="entity-meta-item">
                    <dt>@L["Phone"]</dt>
                    <dd>@Reminder.ClientPhoneNumber</dd>
                </div>
                <div class="entity-meta-item">
                    <dt>@L["Vehicle"]</dt>
                    <dd>@Reminder.VehicleBrand @Reminder.VehicleModel</dd>
                </div>
                <div class="entity-meta-item">
                    <dt>@L["LicensePlate"]</dt>
                    <dd>@Reminder.LicensePlate</dd>
                </div>
            </dl>

            @if (!string.IsNullOrWhiteSpace(ActionErrorMessage))
            {
                <div class="alert alert-danger mt-2 mb-0">@ActionErrorMessage</div>
            }

            @if (!Reminder.IsClosed)
            {
                <div class="action-bar mt-2">
                    <button class="btn btn-success"
                            disabled="@IsBusy"
                            @onclick="ConfirmCloseAsync">
                        @(IsBusy ? L["Reminder_Closing"] : L["Reminder_Close"])
                    </button>
                </div>
            }

            <div class="action-bar action-bar-muted">
                <button class="btn btn-outline-danger btn-sm"
                        disabled="@IsBusy"
                        @onclick="HardDeleteAsync">
                    @L["Archive_HardDelete"]
                </button>
            </div>
        </div>

        <footer class="page-footer-nav">
            <button class="btn btn-secondary btn-sm" @onclick="BackToVehicle">
                @L["BackToVehicle"]
            </button>
        </footer>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ReminderDetailsModel? Reminder { get; set; }
    private bool IsLoading { get; set; }
    private bool IsBusy { get; set; }
    private string? ErrorMessage { get; set; }
    private string? ActionErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            Reminder = await ApiClient.GetReminderAsync(Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void BackToVehicle()
    {
        if (Reminder is not null)
        {
            NavigationManager.NavigateTo($"/vehicles/{Reminder.VehicleId}");
            return;
        }

        NavigationManager.NavigateTo("/schedule");
    }

    private async Task ConfirmCloseAsync()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", L["Reminder_CloseConfirm"]);

        if (!confirmed)
        {
            return;
        }

        await CloseAsync();
    }

    private async Task CloseAsync()
    {
        try
        {
            IsBusy = true;
            ActionErrorMessage = null;

            var updated = await ApiClient.CloseReminderAsync(Id);

            if (updated is null)
            {
                ActionErrorMessage = L["FailedCloseReminder"];
                return;
            }

            Reminder = updated;
        }
        catch (Exception ex)
        {
            ActionErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task HardDeleteAsync()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", L["Reminder_DeleteConfirm"]);
        if (!confirmed)
        {
            return;
        }

        try
        {
            IsBusy = true;
            ActionErrorMessage = null;

            var vehicleId = Reminder?.VehicleId;
            var (success, error) = await ApiClient.DeleteReminderAsync(Id);

            if (!success)
            {
                ActionErrorMessage = error ?? L["Reminder_DeleteFailed"];
                return;
            }

            if (vehicleId.HasValue)
            {
                NavigationManager.NavigateTo($"/vehicles/{vehicleId.Value}");
            }
            else
            {
                NavigationManager.NavigateTo("/schedule");
            }
        }
        catch (Exception ex)
        {
            ActionErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }
}
