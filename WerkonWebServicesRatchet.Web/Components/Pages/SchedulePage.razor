@page "/schedule"
@using WerkonWebServicesRatchet.Web.Models
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>@PageTitleText</PageTitle>

<h1>@PageTitleText</h1>

<div class="d-flex gap-2 align-items-center mb-3 flex-wrap">
    <button class="btn btn-outline-secondary" @onclick="PreviousDayAsync">←</button>

    <input class="form-control"
           style="max-width: 220px;"
           type="date"
           value="@SelectedDateString"
           @onchange="OnDateChanged" />

    <button class="btn btn-outline-secondary" @onclick="NextDayAsync">→</button>

    @if (!IsTodaySelected)
    {
        <button class="btn btn-outline-primary" @onclick="GoToTodayAsync">@L["Today_Button"]</button>
    }
</div>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Visits.Count == 0)
{
    <p>@L["Schedule_NoVisits"]</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@L["Time"]</th>
                <th>@L["Client"]</th>
                <th>@L["Phone"]</th>
                <th>@L["Vehicle"]</th>
                <th>@L["Plate"]</th>
                <th>@L["Complaint"]</th>
                <th>@L["Status"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var visit in Visits)
            {
                <tr>
                    <td>@visit.VisitedAtUtc.ToLocalTime().ToString("HH:mm")</td>
                    <td>@visit.ClientFullName</td>
                    <td>@visit.ClientPhoneNumber</td>
                    <td>@visit.VehicleBrand @visit.VehicleModel</td>
                    <td>@visit.LicensePlate</td>
                    <td>@visit.CustomerComplaint</td>
                    <td>@L.GetVisitStatus(visit.Status)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => OpenVisit(visit.Id)">
                            @L["Open"]
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ScheduleVisitItemModel> Visits { get; set; } = [];
    private DateOnly SelectedDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    private bool IsTodaySelected => SelectedDate == DateOnly.FromDateTime(DateTime.Today);
    private string PageTitleText => IsTodaySelected ? L["Today_Title"] : L["Schedule_Title"];
    private string SelectedDateString => SelectedDate.ToString("yyyy-MM-dd");

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            Visits = await ApiClient.GetVisitsByDayAsync(SelectedDate);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task PreviousDayAsync()
    {
        SelectedDate = SelectedDate.AddDays(-1);
        await LoadAsync();
    }

    private async Task NextDayAsync()
    {
        SelectedDate = SelectedDate.AddDays(1);
        await LoadAsync();
    }

    private async Task GoToTodayAsync()
    {
        SelectedDate = DateOnly.FromDateTime(DateTime.Today);
        await LoadAsync();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (e.Value is null)
        {
            return;
        }

        if (DateOnly.TryParse(e.Value.ToString(), out var parsedDate))
        {
            SelectedDate = parsedDate;
            await LoadAsync();
        }
    }

    private void OpenVisit(Guid visitId)
    {
        NavigationManager.NavigateTo($"/visits/{visitId}");
    }
}
