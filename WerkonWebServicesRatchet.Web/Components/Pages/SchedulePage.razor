@page "/schedule"
@using WerkonWebServicesRatchet.Web.Services
@inject AppTimeZone AppTimeZone

<PageTitle>@PageTitleText</PageTitle>

<h1>@PageTitleText</h1>

<div class="toolbar-bar d-flex gap-2 align-items-center mb-3 flex-wrap">
    <button class="btn btn-outline-secondary" @onclick="PreviousDayAsync">←</button>

    <input class="form-control schedule-date-input"
           type="date"
           value="@SelectedDateString"
           @onchange="OnDateChanged" />

    <button class="btn btn-outline-secondary" @onclick="NextDayAsync">→</button>

    @if (!IsTodaySelected)
    {
        <button class="btn btn-outline-primary" @onclick="GoToTodayAsync">@L["Today_Button"]</button>
    }
</div>

<ScheduleDayView Date="@SelectedDate" ShowTodayMessages="false" />

@code {
    private DateOnly SelectedDate { get; set; }
    private bool IsTodaySelected => SelectedDate == AppTimeZone.GetToday();
    private string PageTitleText => IsTodaySelected ? L["Today_Title"] : L["Schedule_Title"];
    private string SelectedDateString => SelectedDate.ToString("yyyy-MM-dd");

    protected override void OnInitialized()
    {
        SelectedDate = AppTimeZone.GetToday();
    }

    private void PreviousDayAsync()
    {
        SelectedDate = SelectedDate.AddDays(-1);
    }

    private void NextDayAsync()
    {
        SelectedDate = SelectedDate.AddDays(1);
    }

    private void GoToTodayAsync()
    {
        SelectedDate = AppTimeZone.GetToday();
    }

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (e.Value is null)
        {
            return;
        }

        if (DateOnly.TryParse(e.Value.ToString(), out var parsedDate))
        {
            SelectedDate = parsedDate;
        }
    }
}
