@page "/catalog-services"
@using Microsoft.AspNetCore.Components.Authorization
@using WerkonWebServicesRatchet.Web.Models
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MoneyFormatService MoneyFormat
@inject AppPreferencesService AppPreferences

<PageTitle>@L["ServiceCatalog_Title"]</PageTitle>

<h1>@L["ServiceCatalog_Title"]</h1>

<div class="list-filters catalog-services-filters mb-3">
    <div class="filter-field filter-field-inline">
        <label class="form-label" for="catalog-search-filter">@L["Search"]</label>
        <input id="catalog-search-filter" class="form-control" @bind="SearchFilter" @bind:event="oninput" />
    </div>
</div>

<div class="action-bar mb-3">
    <button class="btn btn-primary me-2" @onclick="LoadServicesAsync">@L["Search"]</button>
    <button class="btn btn-secondary me-2" @onclick="ClearFilters">@L["Clear"]</button>
    @if (CanAddCatalog)
    {
        <button class="btn btn-success" @onclick="OpenNewService">@L["ServiceCatalog_Add"]</button>
    }
</div>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Services.Count == 0)
{
    <p>@L["ServiceCatalog_NotFound"]</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@L["ServiceCatalog_Name"]</th>
                <th>@L["ServiceCatalog_Code"]</th>
                <th>@L["ServiceCatalog_Category"]</th>
                <th>@L["UnitPrice"]</th>
                <th>@L["ServiceCatalog_Unit"]</th>
                <th>@L["Status"]</th>
                @if (CanManageCatalog)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var service in Services)
            {
                <tr class="@(CanManageCatalog ? "table-row-action" : "")"
                    @onclick="() => HandleServiceRowClick(service.Id)">
                    <td>@service.Name</td>
                    <td>@(service.Code ?? "—")</td>
                    <td>@(service.Category ?? "—")</td>
                    <td>@MoneyFormat.Format(service.DefaultUnitPrice)</td>
                    <td>@service.DefaultUnit</td>
                    <td>@(service.IsActive ? L["ServiceCatalog_Active"] : L["ServiceCatalog_Inactive"])</td>
                    @if (CanManageCatalog)
                    {
                        <td class="text-end text-nowrap table-row-actions" @onclick:stopPropagation="true">
                            <button type="button"
                                    class="btn-icon-delete"
                                    disabled="@IsDeleting"
                                    title="@L["Delete"]"
                                    aria-label="@L["Delete"]"
                                    @onclick="() => DeleteServiceAsync(service.Id)">
                                <svg class="btn-icon-delete-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
                                </svg>
                            </button>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

    <InfiniteScroll HasMore="HasMore" IsLoading="IsLoadingMore" OnLoadMore="LoadMoreAsync" />
}

@code {
    private List<CatalogServiceListItem> Services { get; set; } = [];
    private string? SearchFilter { get; set; }
    private bool CanManageCatalog { get; set; }
    private bool CanAddCatalog { get; set; }
    private int PageSize => AppPreferences.ListPageSize;
    private bool IsLoading { get; set; }
    private bool IsLoadingMore { get; set; }
    private bool HasMore { get; set; }
    private bool IsDeleting { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var isAdminOrManager = authState.User.IsInRole("Administrator") || authState.User.IsInRole("Manager");
        CanManageCatalog = isAdminOrManager;

        await AppPreferences.EnsureLoadedAsync(ApiClient);
        CanAddCatalog = isAdminOrManager
            || (authState.User.IsInRole("Mechanic") && AppPreferences.MechanicCanAddCatalogServices);

        await LoadServicesAsync();
    }

    private async Task LoadServicesAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            var page = await ApiClient.GetCatalogServicesAsync(SearchFilter, skip: 0, take: PageSize);
            Services = page.Items;
            HasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        if (IsLoadingMore || !HasMore)
        {
            return;
        }

        try
        {
            IsLoadingMore = true;

            var page = await ApiClient.GetCatalogServicesAsync(SearchFilter, skip: Services.Count, take: PageSize);
            Services.AddRange(page.Items);
            HasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoadingMore = false;
        }
    }

    private async Task ClearFilters()
    {
        SearchFilter = null;
        await LoadServicesAsync();
    }

    private void OpenNewService()
    {
        NavigationManager.NavigateTo("/catalog-services/new");
    }

    private void EditService(Guid serviceId)
    {
        NavigationManager.NavigateTo($"/catalog-services/{serviceId}/edit");
    }

    private void HandleServiceRowClick(Guid serviceId)
    {
        if (!CanManageCatalog)
        {
            return;
        }

        EditService(serviceId);
    }

    private async Task DeleteServiceAsync(Guid serviceId)
    {
        try
        {
            IsDeleting = true;
            ErrorMessage = null;
            var (success, deleteError) = await ApiClient.DeleteCatalogServiceAsync(serviceId);

            if (!string.IsNullOrWhiteSpace(deleteError))
            {
                ErrorMessage = deleteError;
                return;
            }

            if (!success)
            {
                return;
            }

            await LoadServicesAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsDeleting = false;
        }
    }
}
