@page "/"
@using WerkonWebServicesRatchet.Web.Services
@inject AppTimeZone AppTimeZone
@inject ThemeService ThemeService
@inject RatchetApiClient ApiClient

<PageTitle>@L["Dashboard_Title"]</PageTitle>

@if (!IsReady)
{
    <p>@L["Loading"]</p>
}
else
{
    <div class="dashboard-page">
        <ScheduleDayView Date="@Today" ShowTodayMessages="true" FullWidth="true" />
    </div>
}

@code {
    private DateOnly Today { get; set; }
    private bool IsReady { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await ApiClient.GetSettingsAsync();

            if (settings is not null)
            {
                if (!string.IsNullOrWhiteSpace(settings.TimeZoneId))
                {
                    AppTimeZone.SetTimeZoneId(settings.TimeZoneId);
                }

                await ThemeService.ApplyAsync(settings.Theme);
            }
        }
        catch
        {
        }

        Today = AppTimeZone.GetToday();
        IsReady = true;
    }
}
