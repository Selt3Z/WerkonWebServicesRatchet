@page "/clients/new"
@page "/clients/{Id:guid}/edit"
@using Microsoft.AspNetCore.Components
@using WerkonWebServicesRatchet.Web.Models
@using WerkonWebServicesRatchet.Web.Services
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>@(IsEditMode ? "Edit Client" : "New Client")</PageTitle>

<h1>@(IsEditMode ? "Edit Client" : "New Client")</h1>

@if (IsLoading)
{
    <p>Loading...</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <EditForm Model="Model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="mb-3">
            <label class="form-label">Full name</label>
            <InputText class="form-control" @bind-Value="Model.FullName" />
            <ValidationMessage For="() => Model.FullName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Phone number</label>
            <InputText class="form-control" @bind-Value="Model.PhoneNumber" />
            <ValidationMessage For="() => Model.PhoneNumber" />
        </div>

        <div class="mb-3">
            <label class="form-label">Notes</label>
            <InputTextArea class="form-control" @bind-Value="Model.Notes" />
        </div>

        <button type="submit" class="btn btn-primary me-2" disabled="@IsSaving">
            @(IsSaving ? "Saving..." : "Save")
        </button>

        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            Cancel
        </button>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private ClientSaveModel Model { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }

    private bool IsEditMode => Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;

        if (!IsEditMode)
        {
            Model = new ClientSaveModel();
            return;
        }

        try
        {
            IsLoading = true;

            var client = await ApiClient.GetClientAsync(Id.Value);

            if (client is null)
            {
                ErrorMessage = "Client not found.";
                return;
            }

            Model = new ClientSaveModel
            {
                FullName = client.FullName,
                PhoneNumber = client.PhoneNumber,
                Notes = client.Notes
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            IsSaving = true;
            ErrorMessage = null;

            ClientListItem? savedClient;

            if (IsEditMode)
            {
                savedClient = await ApiClient.UpdateClientAsync(Id!.Value, Model);
            }
            else
            {
                savedClient = await ApiClient.CreateClientAsync(Model);
            }

            if (savedClient is null)
            {
                ErrorMessage = "Failed to save client.";
                return;
            }

            NavigationManager.NavigateTo($"/clients/{savedClient.Id}");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void Cancel()
    {
        if (IsEditMode)
        {
            NavigationManager.NavigateTo($"/clients/{Id}");
        }
        else
        {
            NavigationManager.NavigateTo("/clients");
        }
    }
}