@page "/users"
@using WerkonWebServicesRatchet.Web.Authorization
@using WerkonWebServicesRatchet.Web.Models
@attribute [RequireAdministrator]
@using WerkonWebServicesRatchet.Web.Services
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager
@inject AppPreferencesService AppPreferences

<PageTitle>@L["Users_Title"]</PageTitle>

<h1>@L["Users_Title"]</h1>

<div class="action-bar mb-3">
    <button class="btn btn-success" @onclick="OpenNewUser">@L["Users_Add"]</button>
</div>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Users.Count == 0)
{
    <p>@L["Users_NotFound"]</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@L["UserName"]</th>
                <th>@L["Name"]</th>
                <th>@L["User_Role"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Users)
            {
                <tr class="table-row-action" @onclick="() => EditUser(user.Id)">
                    <td>@user.UserName</td>
                    <td>@user.DisplayName</td>
                    <td>@L.GetRoleDisplayName(user.Role)</td>
                    <td class="text-end text-nowrap table-row-actions" @onclick:stopPropagation="true">
                        <button type="button"
                                class="btn-icon-delete"
                                disabled="@IsDeleting"
                                title="@L["Delete"]"
                                aria-label="@L["Delete"]"
                                @onclick="() => DeleteUserAsync(user.Id)">
                            <svg class="btn-icon-delete-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
                            </svg>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <InfiniteScroll HasMore="HasMore" IsLoading="IsLoadingMore" OnLoadMore="LoadMoreAsync" />
}

@code {
    private List<UserListItem> Users { get; set; } = [];
    private int PageSize => AppPreferences.ListPageSize;
    private bool IsLoading { get; set; }
    private bool IsLoadingMore { get; set; }
    private bool HasMore { get; set; }
    private bool IsDeleting { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AppPreferences.EnsureLoadedAsync(ApiClient);
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            var page = await ApiClient.GetUsersAsync(skip: 0, take: PageSize);
            Users = page.Items;
            HasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        if (IsLoadingMore || !HasMore)
        {
            return;
        }

        try
        {
            IsLoadingMore = true;

            var page = await ApiClient.GetUsersAsync(skip: Users.Count, take: PageSize);
            Users.AddRange(page.Items);
            HasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoadingMore = false;
        }
    }

    private void OpenNewUser()
    {
        NavigationManager.NavigateTo("/users/new");
    }

    private void EditUser(Guid userId)
    {
        NavigationManager.NavigateTo($"/users/{userId}/edit");
    }

    private async Task DeleteUserAsync(Guid userId)
    {
        try
        {
            IsDeleting = true;
            ErrorMessage = null;
            var (success, deleteError) = await ApiClient.DeleteUserAsync(userId);

            if (!string.IsNullOrWhiteSpace(deleteError))
            {
                ErrorMessage = deleteError;
                return;
            }

            if (!success)
            {
                return;
            }

            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsDeleting = false;
        }
    }
}
