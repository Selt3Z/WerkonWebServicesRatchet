@page "/history"
@attribute [RequireManagerOrAdministrator]
@using WerkonWebServicesRatchet.Web.Authorization
@using WerkonWebServicesRatchet.Web.Models
@using WerkonWebServicesRatchet.Web.Services
@inject RatchetApiClient ApiClient
@inject AppTimeZone AppTimeZone
@inject AppPreferencesService AppPreferences

<PageTitle>@L["History_Title"]</PageTitle>

<h1>@L["History_Title"]</h1>
<p class="form-text">@L["History_Description"]</p>

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Items.Count == 0)
{
    <p>@L["History_Empty"]</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@L["History_DateTime"]</th>
                <th>@L["History_User"]</th>
                <th>@L["History_Action"]</th>
                <th>@L["History_EntityType"]</th>
                <th>@L["History_Record"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    <td>@AppTimeZone.FromUtc(item.OccurredAtUtc).ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.UserDisplayName</td>
                    <td>@L.GetAuditAction(item.Action)</td>
                    <td>@L.GetAuditEntityType(item.EntityType)</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.EntityUrl))
                        {
                            <a href="@item.EntityUrl">@item.Summary</a>
                        }
                        else
                        {
                            @item.Summary
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <InfiniteScroll HasMore="HasMore" IsLoading="IsLoadingMore" OnLoadMore="LoadMoreAsync" />
}

@code {
    private List<AuditLogItemModel> Items { get; set; } = [];
    private int PageSize => AppPreferences.ListPageSize;
    private bool IsLoading { get; set; } = true;
    private bool IsLoadingMore { get; set; }
    private bool HasMore { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AppPreferences.EnsureLoadedAsync(ApiClient);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            var page = await ApiClient.GetAuditLogAsync(skip: 0, take: PageSize);
            Items = page.Items;
            HasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        if (IsLoadingMore || !HasMore)
        {
            return;
        }

        try
        {
            IsLoadingMore = true;

            var page = await ApiClient.GetAuditLogAsync(skip: Items.Count, take: PageSize);
            Items.AddRange(page.Items);
            HasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoadingMore = false;
        }
    }
}
