@using WerkonWebServicesRatchet.Web.Models
@using WerkonWebServicesRatchet.Web.Services
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager
@inject AppTimeZone AppTimeZone
@inject AppPreferencesService AppPreferences

@if (IsLoading)
{
    <p>@L["Loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else
{
    <div class="schedule-split @(FullWidth ? "schedule-split-full" : string.Empty) @(HideRemindersPanel ? "schedule-split-visits-only" : string.Empty)">
        <section class="schedule-panel schedule-panel-visits">
            <h4 class="schedule-section-title">@L["Schedule_VisitsSection"]</h4>
            <div class="schedule-scroll">
                @if (Visits.Count == 0)
                {
                    <p class="schedule-empty">@(ShowTodayMessages ? L["Schedule_NoVisitsToday"] : L["Schedule_NoVisits"])</p>
                }
                else
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>@L["Time"]</th>
                                <th>@L["Client"]</th>
                                <th>@L["Phone"]</th>
                                <th>@L["Vehicle"]</th>
                                <th>@L["Plate"]</th>
                                <th>@L["Complaint"]</th>
                                <th>@L["Schedule_Mechanic"]</th>
                                <th>@L["Status"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visit in Visits)
                            {
                                <tr class="table-row-action" @onclick="() => OpenVisit(visit.Id)">
                                    <td>@AppTimeZone.FromUtc(visit.VisitedAtUtc).ToString("HH:mm")</td>
                                    <td>@visit.ClientFullName</td>
                                    <td>@visit.ClientPhoneNumber</td>
                                    <td>@visit.VehicleBrand @visit.VehicleModel</td>
                                    <td>@visit.LicensePlate</td>
                                    <td>@visit.CustomerComplaint</td>
                                    <td>@(visit.AssignedMechanicDisplayName ?? L["Visit_AssignedMechanic_None"])</td>
                                    <td>@L.GetVisitStatus(visit.Status)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>

        @if (!HideRemindersPanel)
        {
            <section class="schedule-panel schedule-panel-reminders">
                <h4 class="schedule-section-title">@L["Schedule_RemindersSection"]</h4>
                <div class="schedule-scroll">
                    @if (Reminders.Count == 0)
                    {
                        <p class="schedule-empty">@(ShowTodayMessages ? L["Schedule_NoRemindersToday"] : L["Schedule_NoReminders"])</p>
                    }
                    else
                    {
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>@L["Date"]</th>
                                    <th>@L["Client"]</th>
                                    <th>@L["Vehicle"]</th>
                                    <th>@L["Reminder_Note"]</th>
                                    <th>@L["Status"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reminder in Reminders)
                                {
                                    <tr class="table-row-action" @onclick="() => OpenReminder(reminder.Id)">
                                        <td>@AppTimeZone.FromUtc(reminder.ReminderAtUtc).ToString("yyyy-MM-dd")</td>
                                        <td>@reminder.ClientFullName</td>
                                        <td>@reminder.VehicleBrand @reminder.VehicleModel (@reminder.LicensePlate)</td>
                                        <td>@reminder.Note</td>
                                        <td>
                                            @if (reminder.IsClosed)
                                            {
                                                <span class="reminder-check" title="@L["Reminder_Closed"]">✔</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    [Parameter]
    public DateOnly Date { get; set; }

    [Parameter]
    public bool ShowTodayMessages { get; set; }

    [Parameter]
    public bool FullWidth { get; set; }

    private List<ScheduleVisitItemModel> Visits { get; set; } = [];
    private List<ReminderByDayItemModel> Reminders { get; set; } = [];
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    private bool HideRemindersPanel => ShowTodayMessages && !IsLoading && Reminders.Count == 0;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            Visits = await ApiClient.GetVisitsByDayAsync(Date);

            if (ShowTodayMessages)
            {
                await AppPreferences.EnsureLoadedAsync(ApiClient);
                var lookbackDays = AppPreferences.ReminderLookbackDays;
                var fromDate = Date.AddDays(-(lookbackDays - 1));
                Reminders = await ApiClient.GetRemindersByRangeAsync(fromDate, Date);
            }
            else
            {
                Reminders = await ApiClient.GetRemindersByDayAsync(Date);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OpenVisit(Guid visitId)
    {
        NavigationManager.NavigateTo($"/visits/{visitId}");
    }

    private void OpenReminder(Guid reminderId)
    {
        NavigationManager.NavigateTo($"/reminders/{reminderId}");
    }
}
