@inherits LayoutComponentBase

@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inject ApiAuthenticationStateProvider AuthStateProvider
@inject AuthCookieContainer CookieContainer
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager
@inject BrowserSessionCookie BrowserSessionCookie

<div class="app-shell">
    <NavMenu />

    <div class="app-frame">
        <header class="app-titlebar">
            <div class="app-titlebar-leading">
                <span class="app-titlebar-glyph" aria-hidden="true"></span>
                <span class="app-titlebar-caption">@L["AppName"]</span>
            </div>

            <AuthorizeView>
                <Authorized Context="authContext">
                    <AppSettingsInitializer />

                    @{
                        var displayName = authContext.User.FindFirst("display_name")?.Value ?? string.Empty;
                        var role = authContext.User.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;
                    }

                    <div class="app-user-tray">
                        @if (!string.IsNullOrWhiteSpace(displayName))
                        {
                            <span class="app-user-name">@displayName</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(role))
                        {
                            <span class="app-user-role">@L.GetRoleDisplayName(role)</span>
                        }

                        <button type="button" class="btn-logout" @onclick="LogoutAsync" title="@L["Logout"]" aria-label="@L["Logout"]">
                            <svg class="btn-logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 17l5-5-5-5M21 12H9" />
                            </svg>
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </header>

        <main class="app-workspace">
            <div class="app-workspace-well">
                <article class="page-content">
                    @Body
                </article>
            </div>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["BlazorError_Message"]
    <a href="." class="reload">@L["BlazorError_Reload"]</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private async Task LogoutAsync()
    {
        await ApiClient.LogoutAsync();
        CookieContainer.Clear();
        await BrowserSessionCookie.ClearAsync();
        AuthStateProvider.NotifyUserChanged();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
