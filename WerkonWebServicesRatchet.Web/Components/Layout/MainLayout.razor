@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject ApiAuthenticationStateProvider AuthStateProvider
@inject AuthCookieContainer CookieContainer
@inject RatchetApiClient ApiClient
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center gap-3">
            <a href="/about">@L["About"]</a>
            <AuthorizeView>
                <Authorized Context="authContext">
                    @{
                        var role = authContext.User.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;
                    }
                    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                        @if (!string.IsNullOrWhiteSpace(role))
                        {
                            <span class="badge text-bg-secondary">@L.GetRoleDisplayName(role)</span>
                        }
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LogoutAsync">
                            @L["Logout"]
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["BlazorError_Message"]
    <a href="." class="reload">@L["BlazorError_Reload"]</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private async Task LogoutAsync()
    {
        await ApiClient.LogoutAsync();
        CookieContainer.Clear();
        AuthStateProvider.NotifyUserChanged();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
