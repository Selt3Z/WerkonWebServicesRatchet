@using Microsoft.AspNetCore.Components.Authorization
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-sidebar">
    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_Today"]</span>
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/clients">
                    <span class="bi bi-person-bust-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_Clients"]</span>
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/schedule">
                    <span class="bi bi-calendar3-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_Schedule"]</span>
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/catalog-services">
                    <span class="bi bi-wrench-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_ServiceCatalog"]</span>
                </NavLink>
            </div>
        </nav>
    </div>

    <div class="nav-bottom px-3" @onclick:stopPropagation="true">
        <AuthorizeView Roles="Administrator">
            <div class="nav-item">
                <NavLink class="nav-link" href="/users">
                    <span class="bi bi-users-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_Users"]</span>
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="/history">
                    <span class="bi bi-book-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_History"]</span>
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="/settings">
                    <span class="bi bi-gear-nav-menu nav-menu-icon" aria-hidden="true"></span>
                    <span class="nav-menu-text">@L["Nav_Settings"]</span>
                </NavLink>
            </div>
        </AuthorizeView>
    </div>

    <div class="nav-language px-3" @onclick:stopPropagation="true">
        <label class="nav-language-label">@L["Lang_Label"]</label>
        <div class="nav-language-picker">
            <button type="button"
                    class="btn btn-sm btn-outline-light nav-language-toggle w-100"
                    aria-haspopup="listbox"
                    aria-expanded="@IsLanguageMenuOpen"
                    @onclick="ToggleLanguageMenu">
                <span>@L.CurrentLanguage.NativeName</span>
                <span class="nav-language-caret" aria-hidden="true">▾</span>
            </button>

            @if (IsLanguageMenuOpen)
            {
                <ul class="nav-language-menu" role="listbox" aria-label="@L["Lang_Label"]">
                    @foreach (var language in L.AvailableLanguages)
                    {
                        <li role="option" aria-selected="@(language.Code == L.CurrentLanguage.Code)">
                            <button type="button"
                                    class="nav-language-option @(language.Code == L.CurrentLanguage.Code ? "active" : "")"
                                    @onclick="() => SwitchLanguage(language.Code)">
                                @language.NativeName
                            </button>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="nav-about">
            <NavLink class="sidebar-about-link" href="/about">@L["About"]</NavLink>
        </div>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = null!;

    private bool IsLanguageMenuOpen { get; set; }

    private void ToggleLanguageMenu()
    {
        IsLanguageMenuOpen = !IsLanguageMenuOpen;
    }

    private void SwitchLanguage(string cultureCode)
    {
        if (cultureCode.Equals(L.CurrentLanguage.Code, StringComparison.OrdinalIgnoreCase))
        {
            IsLanguageMenuOpen = false;
            return;
        }

        IsLanguageMenuOpen = false;
        NavigationManager.NavigateTo(L.GetCultureSwitchUrl(cultureCode), forceLoad: true);
    }
}
